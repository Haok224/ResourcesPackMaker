                  <Label layoutX="14.0" layoutY="67.0" prefHeight="15.0" prefWidth="58.0" text="描述：" />
                  <TextField fx:id="pack_introduction" layoutX="15.0" layoutY="82.0" prefHeight="23.0" prefWidth="542.0" />
