<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<TabPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" tabClosingPolicy="UNAVAILABLE" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.haok.resourcespackmaker.AppController">
  <tabs>
      <Tab text="基础设置">
        <content>
          <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0">
               <children>
                  <TextField fx:id="pack_name" layoutX="14.0" layoutY="44.0" />
                  <Label layoutX="14.0" layoutY="29.0" prefHeight="15.0" prefWidth="70.0" text="资源包名：" />
                  <Label layoutX="14.0" layoutY="67.0" prefHeight="15.0" prefWidth="58.0" text="描述：" />
                  <TextField fx:id="pack_introduction" layoutX="15.0" layoutY="82.0" prefHeight="23.0" prefWidth="542.0" />
                  <Label layoutX="15.0" layoutY="105.0" text="版本：" />
                  <TextField fx:id="pack_version" layoutX="15.0" layoutY="120.0" />
               </children>
            </AnchorPane>
        </content>
      </Tab>
    <Tab text="字体">
      <content>
        <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0">
               <children>
                  <Label layoutX="114.0" layoutY="38.0" prefHeight="15.0" prefWidth="485.0" text="请选择一个字体文件来更改Minecraft中的字体。" />
                  <TextField fx:id="ttf_path" editable="false" layoutX="90.0" layoutY="86.0" onDragDropped="#ttf_dropped" onDragOver="#ttf_over" prefHeight="23.0" prefWidth="348.0" />
                  <Button fx:id="choose_ttf" layoutX="438.0" layoutY="86.0" mnemonicParsing="false" onAction="#choose_ttf" text="选择文件" />
               </children></AnchorPane>
      </content>
    </Tab>
    <Tab text="主菜单全景图">
      <content>
        <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0">
               <children>
                  <Label layoutX="14.0" layoutY="14.0" text="主菜单全景图就是主菜单后的背景。选择六张图片以更改主菜单全景图。" />
                  <Button layoutX="398.0" layoutY="10.0" mnemonicParsing="false" onAction="#howMake" text="如何制作？" />
               </children></AnchorPane>
      </content>
    </Tab>
      <Tab text="音乐">
        <content>
          <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0" />
        </content>
      </Tab>
      <Tab text="导出">
        <content>
          <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0">
               <children>
                  <TextField fx:id="path" layoutX="14.0" layoutY="38.0" />
                  <Label layoutX="14.0" layoutY="23.0" text="导出路径：" />
                  <CheckBox fx:id="isZip" layoutX="253.0" layoutY="41.0" mnemonicParsing="false" text="制作为压缩包" />
                  <Button fx:id="make" layoutX="47.0" layoutY="125.0" mnemonicParsing="false" text="制作" onAction="#make"/>
                  <Button fx:id="chooseExportPath" layoutX="176.0" layoutY="38.0" mnemonicParsing="false" text="浏览" onAction="#chooseExportPath"/>
               </children></AnchorPane>
        </content>
      </Tab>
  </tabs>
</TabPane>
